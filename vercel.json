{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none';" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/signup",       "destination": "/signup.html" },
    { "source": "/login",        "destination": "/login.html" },
    { "source": "/dashboard",    "destination": "/dashboard.html" },
    { "source": "/profile",      "destination": "/profile.html" },
    { "source": "/discover",     "destination": "/discover.html" },
    { "source": "/matches",      "destination": "/matches.html" },
    { "source": "/messages",     "destination": "/messages.html" },
    { "source": "/videocall",    "destination": "/videocall.html" },
    { "source": "/pricing",      "destination": "/pricing.html" },
    { "source": "/webinars",     "destination": "/webinars.html" },
    { "source": "/analytics",    "destination": "/analytics.html" },
    { "source": "/webinar-host",    "destination": "/webinar-host.html" },
    { "source": "/reset-password",  "destination": "/reset-password.html" },
    { "source": "/user",            "destination": "/user.html" },
    { "source": "/terms",           "destination": "/terms.html" },
    { "source": "/privacy",         "destination": "/privacy.html" },
    { "source": "/refund",          "destination": "/refund.html" }
  ],
  "redirects": [
    { "source": "/signup.html",       "destination": "/signup",       "permanent": true },
    { "source": "/login.html",        "destination": "/login",        "permanent": true },
    { "source": "/dashboard.html",    "destination": "/dashboard",    "permanent": true },
    { "source": "/profile.html",      "destination": "/profile",      "permanent": true },
    { "source": "/discover.html",     "destination": "/discover",     "permanent": true },
    { "source": "/matches.html",      "destination": "/matches",      "permanent": true },
    { "source": "/messages.html",     "destination": "/messages",     "permanent": true },
    { "source": "/videocall.html",    "destination": "/videocall",    "permanent": true },
    { "source": "/pricing.html",      "destination": "/pricing",      "permanent": true },
    { "source": "/webinars.html",     "destination": "/webinars",     "permanent": true },
    { "source": "/analytics.html",    "destination": "/analytics",    "permanent": true },
    { "source": "/webinar-host.html",   "destination": "/webinar-host",   "permanent": true },
    { "source": "/reset-password.html", "destination": "/reset-password", "permanent": true },
    { "source": "/user.html",           "destination": "/user",           "permanent": true },
    { "source": "/terms.html",          "destination": "/terms",          "permanent": true },
    { "source": "/privacy.html",        "destination": "/privacy",        "permanent": true },
    { "source": "/refund.html",         "destination": "/refund",         "permanent": true }
  ]
}
